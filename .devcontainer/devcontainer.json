// See https://aka.ms/vscode-remote/devcontainer.json for format details.
{
	"name": "wait_for_response",
	"dockerFile": "Dockerfile.dev",
	"runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined"],
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"settings": {
				"go.useLanguageServer": true
			},
			"extensions": [
				"golang.go"
			]
		}
	}
}